gas.transport.rocfire.prandtl = 0.69
gas.transport.rocfire.lewis = 1.0
gas.transport.rocfire.lambda_a = 2.13037e-7_cal/cm/s/K^2
gas.transport.rocfire.lambda_b = 5.32743e-6_cal/cm/s/K

gas.eos.type = tpg

chemistry.type = rocfire
# Rocfire rates use A * (P / pressure_reference)^n, matching the original
# 1/bar^n pressure dependence without putting fractional pressure units on A.
chemistry.rocfire.A = 27.0e3_g/cm^3/s 25.3e3_g/cm^3/s 5.0e3_g/cm^3/s 0.4e3_g/cm^3/s
chemistry.rocfire.pressure_exponent = 1.6 1.7 1.7 1.7
chemistry.rocfire.activation_energy = 15.9_kcal/mol 14.5_kcal/mol 11.3_kcal/mol 14.5_kcal/mol
chemistry.rocfire.qgas = 430.0_cal/g 447.0_cal/g 8365.0_cal/g 2127.0_cal/g
# Binder pyrolysis loss is an unresolved 77.5/22.5 AP/HTPB mass-weighted value.
chemistry.rocfire.qsolid = -100.0_cal/g -300.0_cal/g #-145.0_cal/g
chemistry.rocfire.pressure_reference = 1_bar
chemistry.rocfire.nsubsteps = 1

