### AP/HTPB SOURCE ASSUMPTIONS ###
# This is the 20 atm diffuse-source analogue of the gas-injection case.
# AP occupies the center strip (-0.0002 < x < 0.0002); HTPB occupies the two outer strips.
# m0 is an interfacial mass flux [kg/m2/s], not a volumetric density rate.
# Hydro multiplies it by |grad eta| to form the conserved density source.
#
# AP:   m0 = 5.3235 kg/m2/s, T = 830 K, rho_g = P/(R*T) = 7.6350 kg/m3.
# HTPB: m0 = 2.6404 kg/m2/s, T = 889 K, rho_g = P/(R*T) = 7.1283 kg/m3.
# The corresponding normal injection speed is u0 = m0/rho_g.
#
# Cv = Cp - R = (0.3 * 4184) - 319.787 = 935.413 J/kg/K.
# The TPG EOS stores sensible energy relative to T_ref = 298.15 K, so
# rhoE = rho * Cv * (T - T_ref) + 0.5 * rho * |u|^2.

m0.ic.type = expression
m0.ic.expression.region0 = "5.3235 * (x>-0.0002) * (x<0.0002)"
m0.ic.expression.region1 = "2.6404 * ((x<=-0.0002) + (x>=0.0002))"
m0.ic.expression.region2 = "0.0"
m0.ic.expression.region3 = "0.0"
m0.ic.expression.region4 = "0.0"
m0.ic.expression.region5 = "0.0"

u0.ic.type = expression
u0.ic.expression.constant.P = 2026500
u0.ic.expression.constant.T = 700.0
u0.ic.expression.constant.T_final = 3000.0
u0.ic.expression.constant.R = 319.787
u0.ic.expression.region0 = "0.0"
u0.ic.expression.region1 = "5.3235 / (P/R/830.0) * (x>-0.0002)*(x<0.0002) + 2.6404 / (P/R/889.0) * ((x<=-0.0002) + (x>=0.0002))"

q.ic.type = expression
# Additional heat flux only. The total energy carried by m0 is computed from
# the gas-equivalent solid.energy state in Hydro.
q.ic.expression.region0 = "0.0"
q.ic.expression.region1 = "0.0" #"(-53.235 * (x>-0.0002)*(x<0.0002) - 38.2858 * ((x<=-0.0002) + (x>=0.0002)))*41840.0"

density.ic.type = expression
density.ic.expression.constant.eps = 1e-5
density.ic.expression.constant.P = 2026500 # 20 atm
density.ic.expression.constant.T_AP = 830.0
density.ic.expression.constant.T_HTPB = 889.0
density.ic.expression.constant.T_final = 3000.0
density.ic.expression.constant.R = 319.787
density.ic.expression.constant.y_flame = 2.0e-5
density.ic.expression.constant.eps_y = 1.0e-5
density.ic.expression.constant.beta = 7.974
density.ic.expression.constant.gamma = 3.19
density.ic.expression.region0 = "(1.0 - 0.5*(1.0 + erf((y-y_flame)/eps_y))) * P/R/T_AP * (x>-0.0002)*(x<0.0002)"
density.ic.expression.region1 = "(1.0 - 0.5*(1.0 + erf((y-y_flame)/eps_y))) * P/R/T_HTPB * ((x<=-0.0002) + (x>=0.0002))"
density.ic.expression.region2 = "0.0"
density.ic.expression.region3 = "0.0"
density.ic.expression.region4 = "0.0"
density.ic.expression.region5 = "0.5*(1.0 + erf((y-y_flame)/eps_y)) * P/R/T_final"

velocity.ic.type = expression
velocity.ic.expression.constant.P = 2026500
velocity.ic.expression.constant.R = 319.787
velocity.ic.expression.constant.T_AP = 830.0
velocity.ic.expression.constant.T_HTPB = 889.0
velocity.ic.expression.constant.T_final = 3000.0
velocity.ic.expression.constant.y_flame = 2.0e-5
velocity.ic.expression.constant.eps_y = 1.0e-5
velocity.ic.expression.constant.rhou_AP = 5.3235
velocity.ic.expression.constant.rhou_HTPB = 2.6404
velocity.ic.expression.constant.fact = 1.0
velocity.ic.expression.region0 = "0.0"
velocity.ic.expression.region1 = "(1.0 - 0.5*(1.0 + erf((y-y_flame)/eps_y))) * (rhou_AP/(P/R/T_AP) * (x>-0.0002)*(x<0.0002) + rhou_HTPB/(P/R/T_HTPB) * ((x<=-0.0002) + (x>=0.0002))) + 0.5*(1.0 + erf((y-y_flame)/eps_y)) * ((rhou_AP + rhou_HTPB) / (P/R/T_final) / 2.0)"

pressure.ic.type = expression
pressure.ic.expression.region0 = "2026500"

solid.density.ic.type = expression
solid.density.ic.expression.constant.P = 2026500 # 20 atm
solid.density.ic.expression.constant.R = 319.787
solid.density.ic.expression.constant.T = 700.0
solid.density.ic.expression.constant.T_final = 3000.0
solid.density.ic.expression.region0 = "P/R/830.0*(x>-0.0002)*(x<0.0002)"
solid.density.ic.expression.region1 = "P/R/889.0*((x<=-0.0002) + (x>=0.0002))"
solid.density.ic.expression.region2 = "0.0"
solid.density.ic.expression.region3 = "0.0"
solid.density.ic.expression.region4 = "0.0"
solid.density.ic.expression.region5 = "0.0"

solid.momentum.ic.type = expression
solid.momentum.ic.expression.region0 = "0.0"
solid.momentum.ic.expression.region1 = "0.0"

solid.energy.ic.type = expression
solid.energy.ic.expression.constant.P = 2026500 # 20 atm
solid.energy.ic.expression.constant.R = 319.787
solid.energy.ic.expression.constant.T = 700.0
solid.energy.ic.expression.constant.T_final = 3000.0
solid.energy.ic.expression.constant.T0 = 298.15
solid.energy.ic.expression.constant.cv = 935.413
solid.energy.ic.expression.region0 = "(P/R/830.0 * cv*(830.0-T0) + 0.5*5.3235^2/(P/R/830.0)) * (x>-0.0002) * (x<0.0002) + (P/R/889.0 * cv*(889.0-T0) + 0.5*2.6404^2/(P/R/889.0)) * ((x<=-0.0002) + (x>=0.0002))"

