#!/usr/bin/env python3
import sys
sys.path.insert(0,"../../scripts")
import testlib
import glob

outdir = sys.argv[1]
#reference = sys.argv[2]

path = sorted(glob.glob("{}/*cell/".format(outdir)))[-1]

tol = 1.5e-2

testlib.validate(path=path,
                 outdir=outdir,
                 start=[-12,12,0],
                 end=[12,-12,0],
                 vars=["velocityx","velocityy","density"],
                 tolerance=[tol, tol, tol],
                 abs_tolerance=1e8,
                 generate_ref_data = False,
)

exit(0)





