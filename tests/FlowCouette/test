#!/usr/bin/env python3
import sys
sys.path.insert(0,"../../scripts")
import testlib
import glob

outdir = sys.argv[1]
reference = sys.argv[2]
#reference = 'reference/eps0.00.dat'

tol = 1e-2
atol = 1e8

path = sorted(glob.glob("{}/*cell/".format(outdir)))[-1]

testlib.validate(path=path,
                 outdir=outdir,
                 reference=reference,
                 start=[0.08, 0.0],
                 end  =[0.08, 3.0],
                 coord = 'y',
                 vars=["momentumx", "momentumy"],
                 tolerance=[tol, tol],
                 abs_tolerance=[atol, atol],
                 generate_ref_data = False,
                 tight_layout=False,
)


exit(0)





