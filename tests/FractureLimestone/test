#!/usr/bin/env python3
import sys
sys.path.insert(0,"../../scripts")
import testlib
import glob

outdir = sys.argv[1]
#reference = sys.argv[2]

path = sorted(glob.glob("{}/*cell/".format(outdir)))[-1]

testlib.validate(path=path,
                 outdir=outdir,
                 start=[0,0.005,0],
                 end=[0.01,0.005,0],
                 vars=["crack"],
                 tolerance=[0.01],
                 abs_tolerance=100, # basically ignore absolute tolerance
                 generate_ref_data = False,
)


exit(0)







