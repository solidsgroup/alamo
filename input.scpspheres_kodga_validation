
alamo.program = flame

plot_file = output.B_vf_6_00_void_5

system.length = mm
system.time = s

# AMR and output parameters
amr.plot_dt = 2e-4_s
amr.max_grid_size = 4
amr.blocking_factor = 4
amr.base_regrid_int = 10
amr.grid_eff = 0.8
amr.refinement_criterion = 0.5
amr.refinement_criterion_temp = 0.5_K
amr.phi_refinement_criterion = 0.5
amr.cell.all = 1

amr.max_plot_level = 2
#amr.node.all = 1

# Geometry and base grid size
amr.max_level = 4

# Full size
# amr.n_cell = 18 18 18
# geometry.prob_lo = 0.0_mm 0.0_mm 0.0_mm
# geometry.prob_hi = 1.2_mm 1.2_mm 1.2_mm

# Quarter size
amr.n_cell = 128 16 64
geometry.prob_lo = 0.0_mm 0.0_mm 0.0_mm
geometry.prob_hi = 0.2_mm 0.025_mm 0.1_mm

geometry.is_periodic = 0 0 0

## Timestep
timestep = 4e-7_s # [s]
stop_time = 0.08_s

small = 1.0e-10
pf.eps = 1.0_um #0.0005 # [m]
pf.lambda = 0.001_J/m^2

## Eta initial condition

pf.eta.ic.type = psread
pf.eta.ic.psread.file.unit = m
# pf.eta.ic.psread.file.name = new_datasets/A/A_00_void.xyzr
pf.eta.ic.psread.file.name = ../papers/RegressionWithVoidsFullFeedback/results/new_datasets/B_vf_6/B_00_void.xyzr
pf.eta.ic.psread.eps = 1.0_um
pf.eta.ic.psread.invert = 1

